<Window x:Class="IPTVChannelManager.PlayerOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False"
        Topmost="True" IsHitTestVisible="True"
        Focusable="False" ShowActivated="False">
    <Grid>
        <!-- Top info bar: Channel Logo + Real-time clock -->
        <DockPanel x:Name="TopInfoBar" VerticalAlignment="Top" Margin="15,40,15,0">
            <!-- Top-left: Channel Logo -->
            <Border DockPanel.Dock="Left" Background="#60000000" CornerRadius="4" Padding="6,4">
                <StackPanel Orientation="Horizontal">
                    <Image x:Name="ChannelLogoImage" Width="48" Height="48" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock x:Name="ChannelNameText" Foreground="White" FontSize="18"
                               VerticalAlignment="Center" Margin="8,0,0,0" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <!-- Top-right: Real-time clock -->
            <Border DockPanel.Dock="Right" Background="#60000000" CornerRadius="4" Padding="10,4"
                    HorizontalAlignment="Right">
                <TextBlock x:Name="ClockText" Foreground="White" FontSize="14"
                           FontFamily="Consolas" VerticalAlignment="Center"/>
            </Border>
            <UIElement/>
        </DockPanel>

        <!-- Bottom control bar -->
        <Border x:Name="ControlBar" VerticalAlignment="Bottom" Margin="6,0,6,5"
                Background="#90000000" Padding="10,12">
            <DockPanel>
                <!-- Right side: Volume control -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,5,0">
                    <Button x:Name="MuteButton" Click="MuteButton_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            VerticalAlignment="Center" Padding="0">
                        <TextBlock x:Name="VolumeIcon" Text="&#x1F50A;" FontSize="18" Foreground="White" Height="60"/>
                    </Button>
                    <Slider x:Name="VolumeSlider" Width="100" Minimum="0" Maximum="100" Value="100"
                            VerticalAlignment="Center" Margin="4,0,0,0"
                            ValueChanged="VolumeSlider_ValueChanged"
                            Style="{x:Null}"/>
                </StackPanel>

                <!-- Left side: Fullscreen / Restore button -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,0,0">
                    <Button x:Name="FullscreenButton" Click="FullscreenButton_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <TextBlock x:Name="FullscreenIcon" Text="&#x26F6;" FontSize="20" Foreground="White"/>
                    </Button>
                </StackPanel>
                <UIElement/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
