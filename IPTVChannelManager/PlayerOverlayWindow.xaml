<Window x:Class="IPTVChannelManager.PlayerOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False"
        Topmost="True" IsHitTestVisible="True"
        Focusable="False" ShowActivated="False">
    <Grid>
        <!-- Top info bar: Channel Logo + Real-time clock -->
        <DockPanel VerticalAlignment="Top" Margin="{Binding TopInfoBarMargin}">
            <!-- Top-left: Channel Logo -->
            <Border DockPanel.Dock="Left" Background="#60000000" CornerRadius="4" Padding="5,4">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{Binding ChannelLogo}" Height="48" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="{Binding ChannelName}" Foreground="White" FontSize="20"
                               VerticalAlignment="Center" Margin="8,0,0,0" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <!-- Top-right: Real-time clock -->
            <Border DockPanel.Dock="Right" Background="#60000000" CornerRadius="4" Padding="5,4"
                    HorizontalAlignment="Right">
                <TextBlock Text="{Binding ClockText}" Foreground="#60FFFFFF" FontSize="24"
                           FontFamily="Arial" VerticalAlignment="Center"/>
            </Border>
            <UIElement/>
        </DockPanel>

        <!-- Bottom control bar -->
        <Border VerticalAlignment="Bottom" Margin="6,0,6,6" CornerRadius="5"
                Background="#90000000" Padding="10,8"
                Visibility="{Binding ControlBarVisibility}">
            <DockPanel LastChildFill="True">
                <!-- Left side: Fullscreen / Restore button -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,8,0">
                    <Button Command="{Binding ToggleFullscreenCommand}"
                            ToolTip="{Binding FullscreenTooltip}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="5,0">
                        <TextBlock Text="{Binding FullscreenIcon}" FontSize="20" Foreground="White" Height="60"/>
                    </Button>
                </StackPanel>

                <!-- Right side: Volume control -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,5,0">
                    <Button Command="{Binding ToggleMuteCommand}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            VerticalAlignment="Center" Padding="5,0">
                        <TextBlock Text="{Binding VolumeIcon}" FontSize="20" Foreground="White" Height="60"/>
                    </Button>
                    <Slider x:Name="VolumeSlider" Width="100" Minimum="0" Maximum="100"
                            Value="{Binding Volume, Mode=TwoWay}"
                            VerticalAlignment="Center" Margin="6,0,0,0"
                            Style="{x:Null}"/>
                    <!-- Volume percentage label -->
                    <TextBlock Text="{Binding VolumePctText}" Foreground="White" FontSize="14"
                               FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,0,0" Width="40"
                               TextAlignment="Right"/>
                </StackPanel>

                <!-- Center: Media stream info (video codec, audio codec, channels) -->
                <TextBlock Text="{Binding MediaInfoText}" Foreground="#CCFFFFFF" FontSize="16"
                           FontFamily="Consolas" VerticalAlignment="Center" TextAlignment="Center"
                           HorizontalAlignment="Center" TextWrapping="NoWrap"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>